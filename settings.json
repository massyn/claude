{
  "env": {
    "ANTHROPIC_AUTH_TOKEN": "xxxxx",
    "ANTHROPIC_BASE_URL": "https://xxxxx",
    "ANTHROPIC_MODEL": "global-claude-sonnet-4.6-claude-code",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "global-claude-opus-4.6-claude-code",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "global-claude-sonnet-4.6-claude-code",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "global-claude-haiku-4.5-claude-code",
    "CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS": "1",
    "DISABLE_ERROR_REPORTING": "true",
    "DISABLE_TELEMETRY": "true"
},
"permissions": {
    "allow": [
      "Bash(npm:*)",
      "Bash(pnpm:*)",
      "Bash(go:*)",
      "Bash(eslint:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(find:*)",
      "Bash(jest:*)",
      "Bash(pip:*)",
      "Bash(source .venv/bin/activate)",
      "Bash(source venv/bin/activate)",
      "Bash(make:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Edit(*)",
      "WebSearch(*)",
      "MultiEdit(*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:docs.python.org)",
      "WebFetch(domain:pypi.org)",
      "WebFetch(domain:docs.pytest.org)",
      "WebFetch(domain:black.readthedocs.io)",
      "WebFetch(domain:docs.astral.sh)",
      "WebFetch(domain:flask.palletsprojects.com)",
      "WebFetch(domain:fastapi.tiangolo.com)",
      "WebFetch(domain:docs.sqlalchemy.org)",
      "WebFetch(domain:stackoverflow.com)",
      "WebFetch(domain:docs.anthropic.com)"
    ],
    "deny": [
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)"
    ]
  }
}
